# Copy to .env and fill in values
# agentmesh-cli reads this file on startup

# Your deployer/signer private key (0x-prefixed hex)
PRIVATE_KEY=0x...

# RPC URLs — agentmesh will auto-select based on --chain flag
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
MAINNET_RPC_URL=https://eth.llamarpc.com

# Optional: override the default RPC regardless of chain
# RPC_URL=http://127.0.0.1:8545
