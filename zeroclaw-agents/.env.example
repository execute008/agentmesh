# ── Shared ──────────────────────────────────────────────────────────────────
# Ethereum JSON-RPC endpoint
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployed AgentRegistry contract address (from agentmesh-cli deploy)
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Anthropic API key for Claude-powered agents
ANTHROPIC_API_KEY=sk-ant-...

# ── Scraper ─────────────────────────────────────────────────────────────────
# Ethereum private key for the scraper agent (generates its wallet address)
SCRAPER_PRIVATE_KEY=0xdeadbeef...

# WebSocket port (default: 8080)
SCRAPER_PORT=8080

# ── Analyzer ────────────────────────────────────────────────────────────────
# Ethereum private key for the analyzer agent
ANALYZER_PRIVATE_KEY=0xcafebabe...

# Publisher agent's wallet address (for on-chain endpoint lookup)
PUBLISHER_ADDRESS=0x0000000000000000000000000000000000000000

# URL to scrape (default: https://example.com)
TARGET_URL=https://example.com

# WebSocket port (default: 8081)
ANALYZER_PORT=8081

# ── Publisher ───────────────────────────────────────────────────────────────
# Ethereum private key for the publisher agent
PUBLISHER_PRIVATE_KEY=0xfeedface...

# WebSocket port (default: 8082)
PUBLISHER_PORT=8082

# Note: Publisher now also needs RPC_URL and REGISTRY_ADDRESS (shared from top)
