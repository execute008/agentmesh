# Sepolia RPC endpoint — publicnode (free, no key) or Alchemy URL
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Mesh name for deployment — written into meshes.json and emitted on deploy
MESH_NAME=AgentMesh-Demo

# Foundry keystore account name — created via: cast wallet new deployer
DEPLOYER_ACCOUNT=deployer

# Etherscan API key for contract verification (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
